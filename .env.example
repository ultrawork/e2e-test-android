# ========================================
# Notes App — Environment Variables
# ========================================

# --- Infrastructure ---

# Public URL for web application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base URL for API used by mobile apps (iOS/Android)
API_BASE_URL=http://10.0.2.2:3000/api

# VPS server IP address or domain for deployment
VPS_HOST=

# SSH username for VPS deployment
VPS_USER=

# Port number for Express.js backend server
PORT=3000

# Backend API URL for Next.js web client
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# --- Environment ---

# Node.js environment (development/production)
NODE_ENV=development

# --- Credentials (keep empty, set in CI/CD or .env) ---

# Private SSH key for VPS deployment (keep secure!)
VPS_SSH_KEY=

# PostgreSQL connection string for backend database
DATABASE_URL=

# Secret key for signing JWT tokens for authentication
JWT_SECRET=
